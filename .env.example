# Public absolute URL. Used for sitemap, Open Graph and canonical URLs.
APP_URL=https://example.ru

# Runtime mode. PM2 also sets this explicitly in ecosystem.config.cjs.
NODE_ENV=production

# PostgreSQL.
DATABASE_URL=postgresql://autozap_user:CHANGE_ME@localhost:5432/autozap

# Meilisearch. Keep Meilisearch bound to localhost or a private network.
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=CHANGE_ME_LONG_RANDOM_MEILI_MASTER_KEY
MEILI_SEARCH_KEY=

# Admin session signing secret. Use at least 32 random characters.
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SESSION_SECRET_AT_LEAST_32_CHARS

# Optional. If empty, the site shows the Yandex map fallback with route buttons.
YANDEX_MAPS_API_KEY=
